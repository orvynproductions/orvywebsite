{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/admin/dashboard",
      "dest": "/admin/dashboard"
    },
    {
      "src": "/admin",
      "dest": "/admin"
    },
    {
      "src": "/shop",
      "dest": "/shop"
    },
    {
      "src": "/checkout",
      "dest": "/checkout"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
